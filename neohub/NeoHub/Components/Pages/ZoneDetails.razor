@page "/zones/{SessionId}/{PartitionNumber:int}"
@using NeoHub.Services
@using NeoHub.Services.Models
@inject IPanelStateService PanelState
@inject IPanelCommandService PanelCommand
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Zone Details - @partitionDisplayName</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudBreadcrumbs Items="breadcrumbs" Class="mb-4"></MudBreadcrumbs>

    @if (session == null)
    {
        <MudAlert Severity="Severity.Warning">
            Session @SessionId not found
        </MudAlert>
    }
    else if (partition == null)
    {
        <MudAlert Severity="Severity.Warning">
            Partition @PartitionNumber not found
        </MudAlert>
    }
    else
    {
        <MudPaper Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h4">@partitionDisplayName</MudText>
                <MudSpacer />
                <MudChip T="string"
                         Color="@(partition.IsReady ? Color.Success : Color.Warning)"
                         Size="Size.Medium">
                    @partition.EffectiveStatus
                </MudChip>
            </MudStack>
        </MudPaper>

        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h5">
                Zones (@zonesForPartition.Count)
            </MudText>
            <MudSpacer />
            @{
                var openUnbypassed = zonesForPartition.Where(z => z.IsOpen && !z.IsBypassed).ToList();
            }
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Warning"
                       StartIcon="@Icons.Material.Filled.Block"
                       Disabled="@(!openUnbypassed.Any() || _bypassingAll)"
                       OnClick="BypassAllOpenZonesAsync">
                @if (_bypassingAll)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Bypassing...</span>
                }
                else
                {
                    <span>Bypass Open Zones (@openUnbypassed.Count)</span>
                }
            </MudButton>
        </MudStack>

        @if (!zonesForPartition.Any())
        {
            <MudAlert Severity="Severity.Info">
                No zones assigned to this partition
            </MudAlert>
        }
        else
        {
            <MudTable Items="@zonesForPartition" Dense="true" Hover="true" Striped="true">
                <HeaderContent>
                    <MudTh>Zone</MudTh>
                    <MudTh>Name</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>State Flags</MudTh>
                    <MudTh>Other Partitions</MudTh>
                    <MudTh>Last Updated</MudTh>
                    <MudTh>Bypass</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Zone">
                        <MudChip T="string" Size="Size.Small">@context.ZoneNumber</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Name">
                        <MudStack Spacing="0">
                            <MudText>@(context.DisplayNameLine1 ?? $"Zone {context.ZoneNumber}")</MudText>
                            @if (!string.IsNullOrEmpty(context.DisplayNameLine2))
                            {
                                <MudText>@context.DisplayNameLine2</MudText>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@GetZoneColor(context)"
                                 Icon="@GetZoneIcon(context)">
                            @(context.IsOpen ? "OPEN" : "CLOSED")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="State Flags">
                        <MudStack Row="true" Spacing="1">
                            @if (context.IsFaulted)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error">FAULTED</MudChip>
                            }
                            @if (context.IsTampered)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error">TAMPERED</MudChip>
                            }
                            @if (context.IsBypassed)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">BYPASSED</MudChip>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Other Partitions">
                        @{
                            var otherPartitions = context.Partitions.Where(p => p != PartitionNumber).ToList();
                            if (otherPartitions.Any())
                            {
                                <MudText Typo="Typo.caption">@string.Join(", ", otherPartitions)</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                            }
                        }
                    </MudTd>
                    <MudTd DataLabel="Last Updated">
                        <MudText Typo="Typo.caption">@context.LastUpdated.ToLocalTime().ToString("HH:mm:ss")</MudText>
                    </MudTd>
                    <MudTd DataLabel="Bypass">
                        @{
                            var zone = context;
                            var isBusy = _busyZones.Contains(zone.ZoneNumber);
                        }
                        @if (isBusy)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        }
                        else
                        {
                            <MudTooltip Text="@(zone.IsBypassed ? "Unbypass zone" : "Bypass zone")">
                                <MudIconButton Icon="@(zone.IsBypassed ? Icons.Material.Filled.Block : Icons.Material.Outlined.Block)"
                                               Color="@(zone.IsBypassed ? Color.Info : Color.Default)"
                                               Size="Size.Small"
                                               OnClick="@(() => ToggleBypassAsync(zone))" />
                            </MudTooltip>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    }
</MudContainer>

@code {
    [Parameter]
    public string SessionId { get; set; } = "";

    [Parameter]
    public int PartitionNumber { get; set; }

    private SessionState? session;
    private PartitionState? partition;
    private List<ZoneState> zonesForPartition = new();
    private List<BreadcrumbItem> breadcrumbs = new();
    private string partitionDisplayName = "";

    private readonly HashSet<byte> _busyZones = new();
    private bool _bypassingAll;

    private CancellationTokenSource _cts = new();

    protected override void OnInitialized()
    {
        LoadData();

        breadcrumbs = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: ""),
            new BreadcrumbItem($"Session: {SessionId}", href: null, disabled: true),
            new BreadcrumbItem(partitionDisplayName, href: null, disabled: true)
        };
        PanelState.PartitionStateChanged += OnStateChanged;
        PanelState.ZoneStateChanged += OnStateChanged;
    }

    private void LoadData()
    {
        session = PanelState.GetSession(SessionId);
        partition = PanelState.GetPartition(SessionId, (byte)PartitionNumber);
        partitionDisplayName = partition?.DisplayName ?? $"Partition {PartitionNumber}";

        if (session != null)
        {
            zonesForPartition = session.Zones.Values
                .Where(z => z.Partitions.Contains((byte)PartitionNumber))
                .OrderBy(z => z.ZoneNumber)
                .ToList();
        }
    }

    private void OnStateChanged(object? sender, EventArgs e)
    {
        InvokeAsync(() =>
        {
            if (_cts.IsCancellationRequested) return;
            try
            {
                LoadData();
                StateHasChanged();
            }
            catch (ObjectDisposedException) { }
        });
    }

    private async Task ToggleBypassAsync(ZoneState zone)
    {
        if (_busyZones.Contains(zone.ZoneNumber)) return;

        _busyZones.Add(zone.ZoneNumber);
        StateHasChanged();

        var bypassing = !zone.IsBypassed;
        try
        {
            var result = await PanelCommand.BypassZoneAsync(
                SessionId, (byte)PartitionNumber, zone.ZoneNumber, bypassing);

            if (result.Success)
            {
                Snackbar.Add(
                    $"Zone {zone.ZoneNumber} {(bypassing ? "bypassed" : "unbypassed")}",
                    Severity.Success);
            }
            else
            {
                Snackbar.Add($"Bypass failed: {result.ErrorMessage}", Severity.Error);
            }
        }
        finally
        {
            _busyZones.Remove(zone.ZoneNumber);
            StateHasChanged();
        }
    }

    private async Task BypassAllOpenZonesAsync()
    {
        var openUnbypassed = zonesForPartition.Where(z => z.IsOpen && !z.IsBypassed).ToList();
        if (!openUnbypassed.Any()) return;

        _bypassingAll = true;
        StateHasChanged();

        int succeeded = 0;
        int failed = 0;

        try
        {
            foreach (var zone in openUnbypassed)
            {
                if (_cts.IsCancellationRequested) break;

                _busyZones.Add(zone.ZoneNumber);
                StateHasChanged();

                try
                {
                    var result = await PanelCommand.BypassZoneAsync(
                        SessionId, (byte)PartitionNumber, zone.ZoneNumber, bypass: true);

                    if (result.Success)
                        succeeded++;
                    else
                    {
                        failed++;
                        Snackbar.Add($"Zone {zone.ZoneNumber}: {result.ErrorMessage}", Severity.Warning);
                    }
                }
                finally
                {
                    _busyZones.Remove(zone.ZoneNumber);
                }
            }
        }
        finally
        {
            _bypassingAll = false;
            StateHasChanged();
        }

        if (succeeded > 0)
            Snackbar.Add($"{succeeded} zone{(succeeded > 1 ? "s" : "")} bypassed", Severity.Success);
        if (failed > 0)
            Snackbar.Add($"{failed} zone{(failed > 1 ? "s" : "")} failed to bypass", Severity.Error);
    }

    private Color GetZoneColor(ZoneState zone)
    {
        if (zone.IsTampered) return Color.Error;
        if (zone.IsFaulted) return Color.Error;
        if (zone.IsOpen) return Color.Warning;
        if (zone.IsBypassed) return Color.Info;
        return Color.Success;
    }

    private string GetZoneIcon(ZoneState zone)
    {
        if (zone.IsTampered) return Icons.Material.Filled.Error;
        if (zone.IsFaulted) return Icons.Material.Filled.Warning;
        if (zone.IsOpen) return Icons.Material.Filled.LockOpen;
        if (zone.IsBypassed) return Icons.Material.Filled.Block;
        return Icons.Material.Filled.Lock;
    }

    public void Dispose()
    {
        _cts.Cancel();
        PanelState.PartitionStateChanged -= OnStateChanged;
        PanelState.ZoneStateChanged -= OnStateChanged;
        _cts.Dispose();
    }
}

@using NeoHub.Services
@using NeoHub.Services.Models
@using DSC.TLink.ITv2.Enumerations
@implements IDisposable
@inject IPanelUserService UserService
@inject IPanelAccessCodeService AccessCodes
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_disabled)
        {
            @* ─── Disabled view: only the access code input ─── *@
            <MudStack Spacing="3">
                <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Filled.Block">
                    This user is <strong>disabled</strong>. Enter a new
                    <strong>4, 6, or 8 digit</strong> access code and click <em>Enable</em>.
                </MudAlert>

                <MudTextField T="string" @bind-Value="_newCode" Label="New Access Code"
                              Variant="Variant.Outlined"
                              InputType="@(_revealCode ? InputType.Text : InputType.Password)"
                              InputMode="InputMode.numeric"
                              MaxLength="8"
                              Validation="@((string? c) => AccessCodes.ValidateFormat(c))"
                              HelperText="4, 6, or 8 digits"
                              Immediate="true"
                              AutoFocus="true"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_revealCode ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="() => _revealCode = !_revealCode"
                              Style="font-family: 'Courier New', monospace;" />
            </MudStack>
        }
        else
        {
            @* ─── Enabled view: full editor ─── *@
            <MudStack Spacing="4">
                @* Top row: read-only PIN/Proximity indicator on the left, Disable button on the right *@
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Code Type:</MudText>
                        <MudChip T="string" Size="Size.Small"
                                 Variant="@(User.HasProximityTag ? Variant.Outlined : Variant.Filled)"
                                 Color="@(User.HasProximityTag ? Color.Default : Color.Info)"
                                 Icon="@(User.HasProximityTag ? null : Icons.Material.Filled.Check)">
                            PIN
                        </MudChip>
                        <MudChip T="string" Size="Size.Small"
                                 Variant="@(User.HasProximityTag ? Variant.Filled : Variant.Outlined)"
                                 Color="@(User.HasProximityTag ? Color.Info : Color.Default)"
                                 Icon="@(User.HasProximityTag ? Icons.Material.Filled.Check : null)">
                            Proximity Tag
                        </MudChip>
                    </MudStack>
                    <MudTooltip Text="Immediately writes the disable sentinel to this slot. The panel will clear attributes and partitions. Any unsaved edits on this dialog will be discarded.">
                        <MudButton Variant="Variant.Filled" Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Block"
                                   OnClick="DisableAsync"
                                   Disabled="_busy">
                            Disable
                        </MudButton>
                    </MudTooltip>
                </MudStack>

                <MudDivider />

                @* User Label *@
                <MudTextField T="string" @bind-Value="_label" Label="User Label"
                              Variant="Variant.Outlined" MaxLength="14" />

                @* Access Code *@
                <MudTextField T="string" @bind-Value="_code" Label="Access Code"
                              Variant="Variant.Outlined"
                              InputType="@(_revealCode ? InputType.Text : InputType.Password)"
                              InputMode="InputMode.numeric"
                              MaxLength="8"
                              Validation="@((string? c) => AccessCodes.ValidateFormat(c))"
                              HelperText="4, 6, or 8 digits"
                              Immediate="true"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_revealCode ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="() => _revealCode = !_revealCode"
                              Style="font-family: 'Courier New', monospace;" />

                @* Attributes *@
                <MudText Typo="Typo.subtitle2">Attributes</MudText>
                <MudStack Row="true" Spacing="4" Wrap="Wrap.Wrap">
                    @foreach (var (flag, name) in AttributeFlags)
                    {
                        var f = flag;
                        <MudCheckBox T="bool"
                                     Value="@_attributes.HasFlag(f)"
                                     ValueChanged="@(v => ToggleAttribute(f, v))"
                                     Label="@name"
                                     Dense="true" />
                    }
                </MudStack>

                @* Partition Assignments *@
                <MudText Typo="Typo.subtitle2">Partition Assignments</MudText>
                <MudStack Row="true" Spacing="2">
                    @for (int p = 0; p < _partitionAssigned.Length; p++)
                    {
                        var idx = p;
                        <MudCheckBox T="bool"
                                     @bind-Value="_partitionAssigned[idx]"
                                     Label="@($"P{idx + 1}")"
                                     Dense="true" />
                    }
                </MudStack>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync"
                   Disabled="@(_busy || !CanSave)">
            @if (_busy)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @(_disabled ? "Enable" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public PanelUserState User { get; set; } = null!;

    [Parameter]
    public string SessionId { get; set; } = null!;

    [Parameter]
    public int MaxPartitions { get; set; }

    [Parameter]
    public string MasterCode { get; set; } = "";

    // Enabled-view editable state
    private string _label = "";
    private string _code = "";
    private PanelUserAttributes _attributes;
    private bool[] _partitionAssigned = [];

    // Disabled-view editable state (separate field so the display starts empty)
    private string _newCode = "";

    // Common UI state
    private bool _revealCode;
    private bool _busy;
    private CancellationTokenSource? _cts;

    // Dirty-check snapshots for the enabled-view Save path
    private string _origLabel = "";
    private string _origCode = "";
    private PanelUserAttributes _origAttributes;
    private bool[] _origPartitionAssigned = [];

    // Authoritative disabled state follows whatever the panel most recently reported.
    private bool _disabled => User.IsDisabled;

    // Save button enablement depends on which view is active.
    private bool CanSave => _disabled ? AccessCodes.IsValidFormat(_newCode) : AccessCodes.IsValidFormat(_code);

    private static readonly (PanelUserAttributes flag, string name)[] AttributeFlags =
    [
        (PanelUserAttributes.Supervisor,    "Supervisor"),
        (PanelUserAttributes.DuressCode,    "Duress Code"),
        (PanelUserAttributes.CanBypassZone, "Can Bypass Zone"),
        (PanelUserAttributes.RemoteAccess,  "Remote Access"),
        (PanelUserAttributes.BellSquawk,    "Bell Squawk"),
        (PanelUserAttributes.OneTimeUse,    "One-Time Use"),
    ];

    protected override void OnParametersSet() => SyncFromUser();

    /// <summary>
    /// Populates the editable fields and dirty-check snapshots from <see cref="User"/>.
    /// Called on initial dialog open and after each Disable/Enable/Save refresh.
    /// </summary>
    private void SyncFromUser()
    {
        _label = User.UserLabel ?? "";
        // Enabled view binds to the real stored code; disabled view uses _newCode starting empty.
        _code = User.IsDisabled ? "" : (User.CodeValue ?? "");
        _newCode = "";
        _attributes = User.Attributes;

        _partitionAssigned = new bool[MaxPartitions];
        foreach (var p in User.Partitions)
        {
            if (p >= 1 && p <= MaxPartitions)
                _partitionAssigned[p - 1] = true;
        }

        _origLabel = _label;
        _origCode = _code;
        _origAttributes = _attributes;
        _origPartitionAssigned = _partitionAssigned.ToArray();
    }

    private void ToggleAttribute(PanelUserAttributes flag, bool set) =>
        _attributes = set ? _attributes | flag : _attributes & ~flag;

    // ── Disable (immediate write, no Save required) ──

    private async Task DisableAsync()
    {
        if (_busy) return;
        _busy = true;
        StateHasChanged();

        _cts ??= new CancellationTokenSource();
        try
        {
            var result = await UserService.DisableUserAsync(SessionId, User.UserIndex, MasterCode, _cts.Token);
            if (result.Success)
            {
                Snackbar.Add(
                    $"User {User.UserIndex} disabled. Panel-side attributes and partitions were cleared.",
                    Severity.Info);
                MudDialog.Close(DialogResult.Ok(true));
                return;
            }

            Snackbar.Add($"Failed: {result.ErrorMessage}", Severity.Error);
        }
        catch (OperationCanceledException) { /* dialog closed */ }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    // ── Save (enabled view: normal save, disabled view: enable) ──

    private async Task SaveAsync()
    {
        if (_busy || !CanSave) return;

        _busy = true;
        StateHasChanged();

        _cts ??= new CancellationTokenSource();
        try
        {
            if (_disabled)
            {
                var result = await UserService.EnableUserAsync(SessionId, User.UserIndex, _newCode, MasterCode, _cts.Token);
                HandleCrossingResult(result);
                return;
            }

            // Enabled view: normal dirty-check save.
            var trimmedLabel = string.IsNullOrWhiteSpace(_label) ? null : _label.TrimEnd();
            var origTrimmedLabel = string.IsNullOrWhiteSpace(_origLabel) ? null : _origLabel.TrimEnd();

            var edited = new PanelUserState
            {
                UserIndex = User.UserIndex,
                UserLabel = trimmedLabel,
                CodeValue = _code,
                CodeLength = User.CodeLength,
                Attributes = _attributes,
                Partitions = BuildPartitionList(),
                HasProximityTag = User.HasProximityTag,
            };

            var original = new PanelUserState
            {
                UserIndex = User.UserIndex,
                UserLabel = origTrimmedLabel,
                CodeValue = _origCode,
                CodeLength = User.CodeLength,
                Attributes = _origAttributes,
                Partitions = BuildPartitionList(_origPartitionAssigned),
                HasProximityTag = User.HasProximityTag,
            };

            var writeResult = await UserService.WriteUserAsync(SessionId, edited, original, MasterCode, _cts.Token);

            if (writeResult.Success)
            {
                Snackbar.Add($"User {User.UserIndex} saved", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add($"Save failed: {writeResult.ErrorMessage}", Severity.Error);
            }
        }
        catch (OperationCanceledException) { /* dialog closed */ }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private void HandleCrossingResult(PanelUserWriteResult result)
    {
        if (!result.Success || result.UpdatedUser is null)
        {
            Snackbar.Add($"Failed: {result.ErrorMessage}", Severity.Error);
            return;
        }

        // Enable succeeded — refresh in-dialog state so the UI expands into the full editor
        // (attributes, partitions, label). The user stays in the dialog to finish configuring.
        User = result.UpdatedUser;
        SyncFromUser();
    }

    private List<byte> BuildPartitionList(bool[]? assignments = null)
    {
        assignments ??= _partitionAssigned;
        var list = new List<byte>();
        for (int i = 0; i < assignments.Length; i++)
        {
            if (assignments[i])
                list.Add((byte)(i + 1));
        }
        return list;
    }

    private void Cancel() => MudDialog.Cancel();

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}

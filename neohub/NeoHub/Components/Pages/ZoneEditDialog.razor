@using NeoHub.Services.PanelConfiguration
@using NeoHub.Services.PanelConfiguration.Sections
@inject IPanelConfigurationService ConfigService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="4">
            @* ── LCD Label Preview + Editing ── *@
            <MudText Typo="Typo.subtitle2">Zone Label</MudText>
            <div class="lcd-display">
                <input type="text" class="lcd-input" maxlength="14"
                       value="@_line1" @oninput="OnLine1Input"
                       placeholder="Line 1" />
                <input type="text" class="lcd-input" maxlength="14"
                       value="@_line2" @oninput="OnLine2Input"
                       placeholder="Line 2" />
            </div>

            @* ── Zone Definition ── *@
            <MudSelect T="ZoneDefinition"
                       @bind-Value="_definition"
                       Label="Zone Definition"
                       Variant="Variant.Outlined">
                @foreach (var def in Enum.GetValues<ZoneDefinition>())
                {
                    <MudSelectItem T="ZoneDefinition" Value="@def">@FormatEnumName(def.ToString())</MudSelectItem>
                }
            </MudSelect>

            @* ── Zone Attributes [002] ── *@
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2">Functional Attributes</MudText>
                    <MudStack>
                        @foreach (var flag in FunctionalFlags)
                        {
                            var f = flag;
                            <MudCheckBox T="bool"
                                         Value="@_attributes.Functional.HasFlag(f)"
                                         ValueChanged="@(v => ToggleFunctional(f, v))"
                                         Label="@FormatEnumName(f.ToString()).Replace("Is ", "")"
                                         Dense="true" />
                        }
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2">Physical Attributes</MudText>
                    <MudStack>
                        @foreach (var flag in PhysicalFlags)
                        {
                            var f = flag;
                            <MudCheckBox T="bool"
                                         Value="@_attributes.Physical.HasFlag(f)"
                                         ValueChanged="@(v => TogglePhysical(f, v))"
                                         Label="@FormatEnumName(f.ToString()).Replace("Is ", "")"
                                         Dense="true" />
                        }
                    </MudStack>
                </MudItem>
            </MudGrid>

            @* ── Event Reporting [307] ── *@
            <MudText Typo="Typo.subtitle2">Event Reporting</MudText>
            <MudStack Row="true" Spacing="4" Wrap="Wrap.Wrap">
                @foreach (var flag in EventReportingFlags)
                {
                    var f = flag;
                    <MudCheckBox T="bool"
                                 Value="@_eventReporting.HasFlag(f)"
                                 ValueChanged="@(v => ToggleEventReporting(f, v))"
                                 Label="@FormatEnumName(f.ToString())"
                                 Dense="true" />
                }
            </MudStack>

            @* ── Partition Assignments ── *@
            <MudText Typo="Typo.subtitle2">Partition Assignments</MudText>
            <MudStack Row="true" Spacing="2">
                @for (int p = 0; p < _partitionAssigned.Length; p++)
                {
                    var idx = p;
                    <MudCheckBox T="bool"
                                 @bind-Value="_partitionAssigned[idx]"
                                 Label="@($"P{idx + 1}")"
                                 Dense="true" />
                }
            </MudStack>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .lcd-display {
        background-color: #225cf0;
        border: 3px solid #1a1a2e;
        border-radius: 6px;
        padding: 12px 16px;
        box-shadow: inset 0 0 12px rgba(0, 0, 0, 0.4);
        min-height: 72px;
    }

    .lcd-input {
        display: block;
        width: 100%;
        background: transparent;
        border: none;
        border-bottom: 1px solid rgba(224, 232, 255, 0.2);
        outline: none;
        font-family: 'Courier New', Courier, monospace;
        font-size: 18px;
        font-weight: bold;
        letter-spacing: 3px;
        line-height: 1.6;
        color: #e0e8ff;
        text-shadow: 0 0 6px rgba(180, 200, 255, 0.5);
        caret-color: #e0e8ff;
        padding: 2px 0;
    }

    .lcd-input::placeholder {
        color: rgba(224, 232, 255, 0.25);
    }

    .lcd-input:focus {
        border-bottom-color: rgba(224, 232, 255, 0.5);
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int ZoneNumber { get; set; }

    [Parameter]
    public PanelConfigurationState Config { get; set; } = null!;

    [Parameter]
    public string SessionId { get; set; } = null!;

    [Parameter]
    public string InstallerCode { get; set; } = null!;

    private string _line1 = "";
    private string _line2 = "";
    private ZoneDefinition _definition;
    private ZoneAttributes _attributes = new(default, default);
    private ZoneEventReportingAttributes _eventReporting;
    private bool[] _partitionAssigned = [];
    private bool _saving;

    // Original values for dirty checking
    private string _origLabel = "";
    private ZoneDefinition _origDefinition;
    private ZoneAttributes _origAttributes = new(default, default);
    private ZoneEventReportingAttributes _origEventReporting;
    private bool[] _origPartitionAssigned = [];

    private string CombinedLabel => (_line1.PadRight(14) + _line2.PadRight(14)).TrimEnd();

    private static readonly ZoneFunctionalAttributes[] FunctionalFlags = Enum.GetValues<ZoneFunctionalAttributes>()
        .Where(f => f != 0 && ((byte)f & ((byte)f - 1)) == 0)
        .ToArray();

    private static readonly ZonePhysicalAttributes[] PhysicalFlags = Enum.GetValues<ZonePhysicalAttributes>()
        .Where(f => f != 0 && ((byte)f & ((byte)f - 1)) == 0)
        .ToArray();

    private static readonly ZoneEventReportingAttributes[] EventReportingFlags = Enum.GetValues<ZoneEventReportingAttributes>()
        .Where(f => f != 0 && ((byte)f & ((byte)f - 1)) == 0)
        .ToArray();

    protected override void OnParametersSet()
    {
        var zoneIndex = ZoneNumber - 1;
        var zoneDefs = Config.ZoneDefinitions.Values;
        var zoneLabels = Config.ZoneLabels.Values;
        var zoneAttrs = Config.ZoneAttributes.Values;
        var zoneEventReporting = Config.ZoneEventReporting.Values;
        var assignments = Config.ZoneAssignments.Values;
        int maxPartitions = Config.Capabilities.MaxPartitions;

        _definition = zoneIndex < zoneDefs.Count ? zoneDefs[zoneIndex] : ZoneDefinition.NullZone;
        var rawLabel = zoneIndex < zoneLabels.Count ? (zoneLabels[zoneIndex] ?? "") : "";
        _line1 = rawLabel.Length >= 14 ? rawLabel[..14].TrimEnd() : rawLabel.TrimEnd();
        _line2 = rawLabel.Length > 14 ? rawLabel[14..Math.Min(28, rawLabel.Length)].TrimEnd() : "";
        _attributes = zoneIndex < zoneAttrs.Count ? zoneAttrs[zoneIndex] : new ZoneAttributes(default, default);
        _eventReporting = zoneIndex < zoneEventReporting.Count ? zoneEventReporting[zoneIndex] : default;

        _partitionAssigned = new bool[maxPartitions];
        for (int p = 0; p < maxPartitions; p++)
        {
            if (p < assignments.GetLength(0) && zoneIndex < assignments.GetLength(1))
                _partitionAssigned[p] = assignments[p, zoneIndex];
        }

        // Snapshot for dirty checking
        _origLabel = CombinedLabel;
        _origDefinition = _definition;
        _origAttributes = _attributes;
        _origEventReporting = _eventReporting;
        _origPartitionAssigned = _partitionAssigned.ToArray();
    }

    private void OnLine1Input(ChangeEventArgs e) => _line1 = Truncate(e.Value?.ToString(), 14);
    private void OnLine2Input(ChangeEventArgs e) => _line2 = Truncate(e.Value?.ToString(), 14);
    private static string Truncate(string? s, int max) => string.IsNullOrEmpty(s) ? "" : s.Length > max ? s[..max] : s;

    private void ToggleFunctional(ZoneFunctionalAttributes flag, bool set) =>
        _attributes = _attributes with { Functional = set ? _attributes.Functional | flag : _attributes.Functional & ~flag };

    private void TogglePhysical(ZonePhysicalAttributes flag, bool set) =>
        _attributes = _attributes with { Physical = set ? _attributes.Physical | flag : _attributes.Physical & ~flag };

    private void ToggleEventReporting(ZoneEventReportingAttributes flag, bool set) =>
        _eventReporting = set ? _eventReporting | flag : _eventReporting & ~flag;

    private static string FormatEnumName(string name) =>
        System.Text.RegularExpressions.Regex.Replace(name, @"(\p{Ll})(\p{Lu})", "$1 $2")
            .Replace("24 Hour", "24-Hour");

    private async Task SaveAsync()
    {
        _saving = true;
        StateHasChanged();

        try
        {
            var result = await ConfigService.ExecuteInConfigModeAsync(
                SessionId, InstallerCode, readWrite: true, async () =>
                {
                    var errors = new List<string>();
                    var send = ConfigService.CreateWriteDelegate(SessionId);

                    if (_definition != _origDefinition)
                    {
                        var r = await Config.ZoneDefinitions.WriteAsync(send, ZoneNumber, _definition, CancellationToken.None);
                        if (!r.Success) errors.Add($"Definition: {r.ErrorMessage}");
                    }

                    if (_attributes != _origAttributes)
                    {
                        var r = await Config.ZoneAttributes.WriteAsync(send, ZoneNumber, _attributes, CancellationToken.None);
                        if (!r.Success) errors.Add($"Attributes: {r.ErrorMessage}");
                    }

                    if (_eventReporting != _origEventReporting)
                    {
                        var r = await Config.ZoneEventReporting.WriteAsync(send, ZoneNumber, _eventReporting, CancellationToken.None);
                        if (!r.Success) errors.Add($"Event reporting: {r.ErrorMessage}");
                    }

                    if (CombinedLabel != _origLabel)
                    {
                        var r = await Config.ZoneLabels.WriteAsync(send, ZoneNumber, CombinedLabel, CancellationToken.None);
                        if (!r.Success) errors.Add($"Label: {r.ErrorMessage}");
                    }

                    if (!_partitionAssigned.SequenceEqual(_origPartitionAssigned))
                    {
                        for (int p = 0; p < _partitionAssigned.Length; p++)
                        {
                            if (_partitionAssigned[p] != _origPartitionAssigned[p])
                            {
                                var assignments = Config.ZoneAssignments.Values;
                                int maxZones = Config.Capabilities.MaxZones;
                                var zones = new bool[maxZones];
                                for (int z = 0; z < maxZones; z++)
                                {
                                    if (p < assignments.GetLength(0) && z < assignments.GetLength(1))
                                        zones[z] = assignments[p, z];
                                }
                                zones[ZoneNumber - 1] = _partitionAssigned[p];

                                var r = await Config.ZoneAssignments.WriteAsync(send, p + 1, zones, CancellationToken.None);
                                if (!r.Success) errors.Add($"Partition {p + 1} assignment: {r.ErrorMessage}");
                            }
                        }
                    }

                    return errors.Count > 0
                        ? new SectionResult(false, string.Join("; ", errors))
                        : new SectionResult(true);
                }, CancellationToken.None);

            if (result.Success)
            {
                Snackbar.Add($"Zone {ZoneNumber} saved", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add($"Save failed: {result.ErrorMessage}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private SendSectionWrite CreateWriteDelegate() =>
        async (request, token) =>
        {
            var response = await ConfigService.ExecuteInConfigModeAsync(
                SessionId, InstallerCode, readWrite: true,
                () => Task.FromResult(new SectionResult(true)),
                token);
            return response;
        };

    private void Cancel() => MudDialog.Cancel();
}
